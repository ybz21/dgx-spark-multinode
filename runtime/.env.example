# ============================================================
# DGX Spark 双节点推理配置
# cp .env.example .env && vim .env
# ============================================================

# ---- Docker 镜像 ----
VLLM_IMAGE=ghcr.nju.edu.cn/bjk110/vllm-spark:v019-ngc2603

# ---- 模型 ----
# 本机模型路径 (两台机器需一致)
MODEL_PATH=/home/ai/models/Qwen3___5-122B-A10B-NVFP4
# 容器内挂载路径
MODEL_CONTAINER_PATH=/models/Qwen3___5-122B-A10B-NVFP4
# API 返回的模型名
SERVED_MODEL_NAME=Qwen3.5-122B-A10B-NVFP4

# ---- 集群 ----
# TP=1 单机, TP=2 双节点
TP_SIZE=2
# 高速网 IP (ConnectX-7 光缆直连)
HEAD_ROCE_IP=10.0.0.1
WORKER_ROCE_IP=10.0.0.2
# 高速网口名 (两台需一致，用 ip link show 查看)
ROCE_IF_NAME=enp1s0f0np0
IB_HCA_NAME=rocep1s0f0
RAY_PORT=6379

# ---- vLLM 服务 ----
HOST_PORT=30000
MAX_MODEL_LEN=8192
MAX_NUM_SEQS=4
GPU_MEMORY_UTILIZATION=0.85
MAX_NUM_BATCHED_TOKENS=8192

# ---- 额外参数 ----
VLLM_EXTRA_ARGS=--enable-chunked-prefill --reasoning-parser qwen3 --enable-auto-tool-choice --tool-call-parser qwen3_coder

# ---- 量化相关 (一般不需要改) ----
VLLM_MARLIN_USE_ATOMIC_ADD=0
VLLM_USE_FLASHINFER_MOE_FP4=0
VLLM_NVFP4_MOE_FORCE_MARLIN=0

# ---- GLOO 接口 (两台管理网口名需一致) ----
GLOO_IF_NAME=enP7s7
