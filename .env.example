# ============================================================
# DGX Spark 多节点推理 - 配置模板
# cp .env.example .env && vim .env
# ============================================================

# --- 节点列表 ---
# 格式: 管理网IP,高速网IP,SSH用户名,主机名
NODE_LIST=(
    "192.168.130.16,10.0.0.1,ai,spark-node1"
    "192.168.130.8,10.0.0.2,ai,spark-node2"
)

# --- 高速网络配置 ---
FAST_SUBNET=24
FAST_MTU=9000

# --- 模型配置 ---
MODEL_PATH=/home/ai/models/YOUR_MODEL_HERE

# --- SGLang 配置 ---
SGLANG_IMAGE=sglang-dev-cu13-accel:latest
SGLANG_PORT=30000
NCCL_INIT_PORT=29500
TP_SIZE=2
ATTENTION_BACKEND=triton
MEM_FRACTION=0.8
QUANTIZATION=
EXTRA_ARGS="--trust-remote-code"

# --- 自定义 Patch (可选) ---
# CUSTOM_SCRIPTS_DIR=/home/ai/lm_scripts/services
# CUSTOM_FILES="sglang_entrypoint.sh"
# CUSTOM_ENTRYPOINT=sglang_entrypoint.sh
