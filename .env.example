# ============================================================
# DGX Spark 多节点推理 - 全局配置
# 复制此文件为 .env 并修改: cp .env.example .env
# 改完后执行: bash deploy.sh restart
# ============================================================

# --- 节点列表 ---
# 格式: 管理网IP,高速网IP,SSH用户名,主机名[,光口接口名]
# 第一个节点自动作为 HEAD (rank 0)，其余为 WORKER
# 添加/删除行即可增减节点，deploy.sh 会自动识别
#
# 光口接口名可省略，脚本会自动检测有光缆的 ConnectX-7 口
# 也可手动指定，适用于多根光缆只想用其中一个口的场景
NODE_LIST=(
    "192.168.1.100,10.10.10.1,ai,spark-node1"
    "192.168.1.101,10.10.10.2,ai,spark-node2"
)

# --- 高速网络配置 ---
FAST_SUBNET=24
FAST_MTU=9000

# --- 模型配置 ---
# 模型在每台机器上的本地路径 (需保持一致，提前拷贝到每台机器)
MODEL_PATH=/home/ai/models/YOUR_MODEL_NAME

# --- SGLang 配置 ---
SGLANG_IMAGE=nvcr.io/nvidia/sglang:26.03-py3
SGLANG_PORT=30000
NCCL_INIT_PORT=29500
# tensor parallel 数 = 节点数 (每台1个GPU)
TP_SIZE=2
ATTENTION_BACKEND=triton
MEM_FRACTION=0.8
# 量化方式 (留空=不量化, 可选: modelopt_fp4)
QUANTIZATION=
# 额外 SGLang 参数
EXTRA_ARGS="--trust-remote-code"

# --- 自定义 Patch (可选) ---
# 自定义 reasoning detector 和 entrypoint 脚本路径 (在每台机器上的路径)
# 用于 patch SGLang，例如: <tool_call> 出现在 <think> 中时自动结束思考
# 留空则不挂载自定义脚本
CUSTOM_SCRIPTS_DIR=
CUSTOM_REASONING_DETECTOR=
CUSTOM_ENTRYPOINT=
